# ── Mobile client environment variables ──────────────────────
# Copy this file to .env and fill in your values.
# Restart `expo start` after changing this file — app.config.js only
# re-reads it at startup, not on hot reload.

# ── Which environment defaults to use: development | production ─
APP_ENV=development

# ── API / Backend ─────────────────────────────────────────────
# Explicit override — if set, this wins over everything below,
# regardless of APP_ENV. Handy for pointing at a teammate's server
# or a staging deploy without touching APP_ENV.
# API_BASE_URL=http://192.168.1.105:5000

# Used when APP_ENV=development and API_BASE_URL is not set.
# NOTE: unlike the web client's Vite dev server, there's no proxy here —
# the app talks to this URL directly. "localhost" / "127.0.0.1" means
# the phone itself when testing on a real device via Expo Go, not your
# computer. Use your machine's LAN IP instead:
#   ipconfig (Windows) or ifconfig / ip a (Mac/Linux) → look for 192.168.x.x
# Example:
# API_BASE_URL_DEV=http://192.168.1.105:5000
#
# Android emulator specifically: 127.0.0.1 inside the emulator means the
# emulator itself, not your host machine (same root cause as the physical
# device case above, different fix). Android's emulator reserves 10.0.2.2
# as an alias for the host machine's loopback, so use that instead of your
# LAN IP when running in an emulator (not needed for a physical Android
# device — use the LAN IP there, same as iOS):
# API_BASE_URL_DEV=http://10.0.2.2:5000
#
# iOS Simulator is the one case that can use 127.0.0.1 directly, since it
# shares the host machine's network stack.
API_BASE_URL_DEV=http://127.0.0.1:5000

# Used when APP_ENV=production and API_BASE_URL is not set.
# Same Railway backend the website (client/) talks to.
API_BASE_URL_PROD=https://preppak-production.up.railway.app
