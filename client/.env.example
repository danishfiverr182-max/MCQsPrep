# ── Client environment variables ─────────────────────────────
# Copy this file to .env and fill in your values.

# ── API / Backend ─────────────────────────────────────────────
VITE_API_URL=http://localhost:5000

# ── Mobile / LAN testing ──────────────────────────────────────
# When testing on a real phone on the same WiFi, Vite proxies /api
# to 127.0.0.1:5000 but 127.0.0.1 is the phone itself, not your PC.
# Set this to your machine's LAN IP so the proxy reaches the server:
#   ipconfig (Windows) or ifconfig / ip a (Mac/Linux) → look for 192.168.x.x
# Example:
# VITE_API_TARGET=http://192.168.1.105:5000
VITE_API_TARGET=http://127.0.0.1:5000

# ── Admin secret path ─────────────────────────────────────────
# Must match ADMIN_SECRET_PATH on the server.
VITE_ADMIN_PATH=/admin-x9k2

# ── Public site URL ───────────────────────────────────────────
# Used by useSeoMeta and SeoHead to generate canonical URLs and
# JSON-LD structured data.  In production set this to your real domain.
# Example: https://www.prepkp.com
VITE_PUBLIC_URL=http://localhost:5173
